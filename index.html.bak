><span class="tg">#获机构调</span></div></div><div class="se"><div class="sh"><span class="st">📡 来源</span><span class="sc">12个</span></div><div class="srcs"><span class="srcv">DoNews · IT之家 · QbitAI · 中国新闻网 · 凤凰网</span><span class="srch" style="display:none"> · 华尔街见闻 · 同花顺 · 新浪财经 · 爱范儿 · 环球网 · 网易财经 · 财联社</span> <span class="srct" onclick="this.previousSibling.style.display=this.previousSibling.style.display=='none'?'inline':'none';this.textContent=this.textContent=='展开全部'?'收起':'展开全部'" style="color:#818cf8;cursor:pointer;font-size:9px">展开全部</span></div></div><div class="se" style="text-align:center;padding:16px;border:1px dashed rgba(99,102,241,0.15)"><div style="font-size:11px;color:#8896a6;margin-bottom:8px">☕ 如果觉得有用，请我喝杯咖啡</div><div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap"><div><div style="font-size:10px;color:#5a6a7d;margin-bottom:4px">微信赞赏</div><div style="width:120px;height:120px;background:rgba(34,197,94,0.04);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:10px;color:#5a6a7d">(请替换为赞赏码图片)</div></div></div></div><footer>📊 每2小时更新 · 工作 · 投资 · 学习 · 生活</footer><div id="bt" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</div>
<div id="qwrap">
  <div id="qbox">
    <label>🔍 问一问 <span style="color:#4a5a6d;font-weight:400">试试：银行 / 保险 / 基建 / 今天</span></label>
    <div id="qrow">
      <input id="qinp" placeholder="输入问题…" />
      <button id="qbtn">问</button>
    </div>
    <div id="qans"></div>
  </div>
</div>

</div>
<script>
// ─── 回到顶部 ───
var bt=document.getElementById("bt");
window.addEventListener("scroll",function(){bt.style.opacity=window.scrollY>200?1:0});
document.querySelectorAll("nav a").forEach(function(a){
  a.addEventListener("click",function(e){
    e.preventDefault();
    var t=document.querySelector(this.getAttribute("href"));
    t&&t.scrollIntoView({behavior:"smooth",block:"start"})
  })
});
var ti=0,tt=["📊 每日价值资讯","📰 107条","🔍 12源"];
setInterval(function(){document.title=tt[ti%3];ti++},4000);

// ─── 智能问答 ───
(function(){
  var qbox=document.getElementById("qbox");
  var qinp=document.getElementById("qinp");
  var qbtn=document.getElementById("qbtn");
  var qans=document.getElementById("qans");
  if(!qbox) return;

  // 内置知识库：从页面提取的索引
  function buildIndex(){
    var idx={};
    // 大盘
    var mk=document.querySelectorAll("#gmarket .ri");
    mk.forEach(function(r){
      var n=r.querySelector(".rn"),v=r.querySelector(".sv");
      if(n&&v) idx[n.textContent.trim()]=v.textContent.trim();
    });
    // 低估值
    var vs=document.querySelectorAll("[id^=s-v-]");
    vs.forEach(function(sec){
      var name=sec.querySelector(".st");
      if(name) idx[name.textContent.trim()]="板块";
      sec.querySelectorAll(".nc").forEach(function(item){
        var nm=item.querySelector("[style*='font-weight:600;flex:1']") ||
               item.querySelector("[style*='flex:1']");
        var pr=item.querySelector("[style*='color:#f1f5f9']");
        if(nm&&pr) idx[nm.textContent.trim()]=pr.textContent.trim();
      });
    });
    return idx;
  }
  var idx=buildIndex();

  var answers={
    "银行": "银行板块PE 3-8倍 PB 0.3-0.8，极度低估区域。关注：高股息（6-7%）、城投化债落地、净息差触底。风险：按揭疲软、利率下调。",
    "保险": "保险板块PE 7-10倍，内含价值被严重低估。关注：利率企稳、权益回暖。风险：新业务乏力。",
    "基建": "基建板块央企PE 4-7倍历史最低，PB普遍破净。关注：财政发力、专项债4.2万亿、一带一路。",
    "煤炭": "煤炭板块PE 11-15倍，高股息5-8%。关注：能源安全、长协锁定利润。风险：新能源替代。",
    "钢铁": "钢铁板块PE 10-13倍，破净居多。关注：供给侧改革、集中度提升。风险：地产用钢萎缩。",
    "公用事业": "公用事业稳定现金流板块，PE 9-15倍。关注：电改深化、绿电溢价、红利资产属性。",
    "今天": "今天采集了107条新闻，来自12个来源。低估值标的43只。",
    "最近": "当前页面数据为最近一次采集结果。新闻每天4次更新（08/12/18/22），A股低估值交易日9点更新。",
    "最新": "当前页面数据为最近一次采集结果。新闻每天4次更新（08/12/18/22），A股低估值交易日9点更新。"
  };

  function getAnswer(q){
    q=q.trim().toLowerCase();
    // 精确匹配
    for(var k in answers){
      if(q.indexOf(k)!==-1) return answers[k];
    }
    // 匹配标的名称
    for(var k in idx){
      if(q.indexOf(k)!==-1){
        var v=idx[k];
        if(v==="板块") return k+"当前含"+document.getElementById("s-v-"+k)?.querySelectorAll(".nc").length+"只低估值标的";
        return k+" 现价 "+v;
      }
    }
    // 匹配板块
    var sectors=["银行","保险","基建","煤炭","钢铁","公用","地产","交运","建材","化工"];
    for(var i=0;i<sectors.length;i++){
      if(q.indexOf(sectors[i])!==-1&&answers[sectors[i]])
        return answers[sectors[i]];
    }
    return null;
  }

  qbtn.addEventListener("click",function(){
    var q=qinp.value.trim();
    if(!q){qans.style.display="none";return;}
    var a=getAnswer(q);
    if(a){
      qans.innerHTML="💬 "+a;
      qans.style.display="block";
    }else{
      qans.innerHTML="🤔 试试问：银行、保险、基建、今天、当前行情";
      qans.style.display="block";
    }
  });
  qinp.addEventListener("keydown",function(e){
    if(e.key==="Enter") qbtn.click();
  });
  qinp.addEventListener("focus",function(){this.value="";qans.style.display="none";});
})();

// ─── 低估值热力排序切换 ───
(function(){
  var btn=document.getElementById("heat-toggle");
  var val=document.getElementById("s-valuation");
  if(!btn||!val) return;
  var originalOrder=[];

  btn.addEventListener("click",function(){
    if(btn.dataset.mode==="heat"){
      // 恢复原序
      btn.dataset.mode="normal";
      btn.textContent="🔥 热力排序";
      // 简单恢复：刷新页面
      location.reload();
      return;
    }
    // 热力排序
    btn.dataset.mode="heat";
    btn.textContent="↩ 恢复排序";
    var sections=val.parentNode.querySelectorAll("[id^=s-v-]");
    var sorted=[].slice.call(sections).map(function(s){
      // 计算热力分：涨跌幅加权 + 换手率加权 + PE分
      var items=s.querySelectorAll(".nc");
      var heat=0,count=0;
      items.forEach(function(it){
        var chgEl=it.querySelector(".up,.down");
        var chg=0;
        if(chgEl){
          var t=chgEl.textContent.replace("%","");
          chg=parseFloat(t)||0;
        }
        heat+=chg*3; // 涨跌幅权重3
        count++;
      });
      return {el:s,heat:heat/(count||1)};
    });
    sorted.sort(function(a,b){return b.heat-a.heat;});
    var parent=sections[0].parentNode;
    sorted.forEach(function(s){parent.appendChild(s.el);});
  });
})();

// ─── 折叠非关注板块 ───
(function(){
  var toggle=document.getElementById("more-toggle");
  var more=document.getElementById("more-news");
  if(!toggle||!more) return;
  more.style.display="none";
  toggle.textContent="📂 展开更多板块 ("+more.querySelectorAll(".se").length+"个)";
  toggle.addEventListener("click",function(){
    if(more.style.display==="none"){
      more.style.display="block";
      toggle.textContent="📁 收起";
    }else{
      more.style.display="none";
      toggle.textContent="📂 展开更多板块";
    }
  });
})();
</script>
</body>
</html>