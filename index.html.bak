<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<meta http-equiv=Content-Security-Policy content="default-src &#39;self&#39;; style-src &#39;unsafe-inline&#39; &#39;self&#39;; script-src &#39;unsafe-inline&#39; &#39;self&#39;; img-src &#39;self&#39; data: https:; connect-src &#39;self&#39;; frame-src &#39;none&#39;; object-src &#39;none&#39;">
<title>📊 每日价值资讯</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0b0e16;color:#e2e8f0;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Microsoft YaHei",sans-serif;line-height:1.6;min-height:100vh}
.app{max-width:100%;margin:0 auto;padding:0 20px 50px}
header{padding:14px 20px 8px;position:sticky;top:0;background:rgba(11,14,22,0.95);z-index:10;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,0.02);max-width:100%;margin:0 auto}
.top{display:flex;justify-content:space-between;align-items:center}
.tl{font-size:18px;font-weight:700;background:linear-gradient(135deg,#f59e0b,#ef4444,#8b5cf6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.sub{font-size:9px;color:#4a5a6d;display:flex;gap:8px;align-items:center;margin:1px 0 3px}
.gr{color:#22c55e;font-size:9px;font-weight:500}
.live{width:4px;height:4px;background:#ef4444;border-radius:50%;display:inline-block;animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.wbar{font-size:9px;color:#5a6a7d;padding:1px 0}
nav{display:flex;gap:2px;overflow-x:auto;scrollbar-width:none;margin:2px 0 4px}
nav a{color:#5a6a7d;text-decoration:none;font-size:9px;padding:3px 8px;border-radius:10px;background:rgba(255,255,255,0.02);flex-shrink:0;white-space:nowrap}
nav a:hover{background:rgba(59,130,246,0.06);color:#60a5fa}

/* 卡片容器 */
.se{background:linear-gradient(135deg,#13182a 0%,#111524 100%);border:1px solid rgba(42,48,69,0.15);border-radius:10px;padding:10px;margin-bottom:7px;animation:fi .35s ease;transition:border-color .3s,box-shadow .3s}
.se:hover{border-color:rgba(99,102,241,0.15);box-shadow:0 0 20px rgba(99,102,241,0.03)}

/* 宽屏布局 */
@media(min-width:1024px){
  .val-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .news-two{display:grid;grid-template-columns:1fr 1fr;gap:6px}
}
@media(max-width:600px){
  .val-grid .se{margin-bottom:6px}
  .news-two .se{margin-bottom:6px}
}
.index-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:4px;margin-top:4px}
.idx{background:rgba(255,255,255,0.02);border-radius:8px;padding:8px 10px;display:flex;flex-direction:column;gap:3px;transition:background .2s}
.idx:hover{background:rgba(99,102,241,0.04)}
.idx-n{font-size:10px;color:#6b7a8d}
.idx-p{font-size:14px;font-weight:600;color:#f1f5f9}
.idx-c{font-size:10px;font-weight:500}
.fund-flow{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-top:6px}
.ff-item{background:rgba(255,255,255,0.02);border-radius:6px;padding:6px 8px;display:flex;justify-content:space-between;align-items:center;font-size:9px}
.ff-label{color:#6b7a8d}
.ff-val{font-weight:600}
.ff-val.inflow{color:#ef4444}
.ff-val.outflow{color:#22c55e}

/* 卡片内网格 */
.card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:4px;margin:6px 0}
.card-item{background:rgba(255,255,255,0.02);border-radius:6px;padding:6px 8px;font-size:10px;display:flex;flex-direction:column;gap:2px;transition:background .2s}
.card-item:hover{background:rgba(59,130,246,0.03)}
.card-t{color:#8896a6;font-size:9px}
.card-v{color:#f1f5f9;font-weight:600;font-size:11px}
.card-c{font-size:9px}
.card-c.up{color:#22c55e}.card-c.down{color:#ef4444}
@keyframes fi{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.sh{display:flex;align-items:center;gap:6px;margin-bottom:4px;padding-bottom:4px;border-bottom:1px solid rgba(255,255,255,0.02)}
.st{font-size:12px;font-weight:600;color:#f1f5f9}
.sc{font-size:9px;color:#4a5a6d;margin-left:auto;background:rgba(99,102,241,0.04);padding:1px 6px;border-radius:8px}

/* 头条卡片 */
.hl{padding:6px 4px;cursor:pointer;margin:0 -2px;border-radius:6px;display:flex;align-items:center;gap:5px;flex-wrap:wrap;border-bottom:1px solid rgba(255,255,255,0.008);transition:background .2s}
.hl:last-child{border-bottom:none}
.hl:hover{background:rgba(99,102,241,0.04)}
.hb{display:inline-flex;width:18px;height:18px;color:#fff;font-size:9px;font-weight:700;border-radius:4px;align-items:center;justify-content:center;flex-shrink:0}
.ht{font-size:12px;font-weight:600;flex:1;line-height:1.4;color:#f1f5f9}
.hs{font-size:8px;color:#4a5a6d;flex-shrink:0;display:flex;align-items:center;gap:3px}
.rbadge{font-size:7px;color:#f59e0b;background:rgba(245,158,11,0.06);padding:0 4px;border-radius:3px}

/* 新闻条目卡片 */
.nc{padding:5px 4px;cursor:pointer;margin:0 -2px;border-radius:6px;display:flex;align-items:center;gap:5px;border-bottom:1px solid rgba(255,255,255,0.008);transition:background .2s,border-color .2s}
.nc:last-child{border-bottom:none}
.nc:hover{background:rgba(59,130,246,0.03);border-left:2px solid rgba(59,130,246,0.2);padding-left:6px}
.ni{display:inline-flex;width:15px;height:15px;color:#fff;font-size:8px;font-weight:700;border-radius:3px;align-items:center;justify-content:center;flex-shrink:0}
.nn{font-size:11px;flex:1;line-height:1.4;color:#e2e8f0}
.ns{font-size:8px;color:#4a5a6d;flex-shrink:0;background:rgba(255,255,255,0.02);padding:1px 5px;border-radius:4px}

/* 行情网格 */
.sg{display:grid;grid-template-columns:1fr 1fr;gap:3px}
.si{display:flex;gap:4px;background:rgba(255,255,255,0.02);border-radius:6px;padding:4px 8px;align-items:center;transition:background .2s}
.si:hover{background:rgba(99,102,241,0.04)}
.sn{font-size:8px;color:#6b7a8d;min-width:38px;flex-shrink:0}
.sv{font-size:11px;font-weight:600;margin-left:auto;color:#f1f5f9}
.sc2{font-size:9px;font-weight:500;min-width:45px;text-align:right;flex-shrink:0}
.up{color:#22c55e}.down{color:#ef4444}
.fg,.rg{display:grid;grid-template-columns:1fr 1fr;gap:3px}
.fi{display:flex;justify-content:space-between;background:rgba(255,255,255,0.02);border-radius:5px;padding:3px 8px;font-size:10px;transition:background .2s}
.fi:hover{background:rgba(99,102,241,0.03)}
.fv{font-weight:600;color:#f1f5f9}
.ri{display:flex;justify-content:space-between;background:rgba(255,255,255,0.02);border-radius:5px;padding:3px 8px;font-size:10px;transition:background .2s}
.ri:hover{background:rgba(99,102,241,0.03)}
.rn{color:#6b7a8d}
.rv{font-weight:600;color:#818cf8}
.vi{display:flex;gap:3px;background:rgba(255,255,255,0.02);border-radius:5px;padding:3px 8px;font-size:9px;align-items:center;transition:background .2s}
.vi:hover{background:rgba(99,102,241,0.03)}
.vr{color:#4a5a6d;min-width:12px;text-align:center}
.vn{flex:1;font-weight:500;color:#e2e8f0}
.vp{min-width:40px;text-align:right}
.vc{min-width:42px;text-align:right}
.vv{color:#4a5a6d;min-width:35px;text-align:right}

/* 量化选股 */
.qi{display:flex;gap:3px;background:rgba(255,255,255,0.02);border-radius:5px;padding:4px 8px;font-size:9px;align-items:center;cursor:pointer;transition:background .2s}
.qi:last-child{border-bottom:none}
.qi:hover{background:rgba(59,130,246,0.04)}
.qr{color:#4a5a6d;min-width:12px;text-align:center}
.qn{flex:1;font-weight:500;color:#e2e8f0}
.qch{min-width:44px;text-align:right;font-weight:600}
.qpe{color:#4a5a6d;min-width:34px;text-align:right}
.qsc{color:#818cf8;min-width:22px;text-align:right;font-weight:600}

/* 热词 */
.tgs{display:flex;flex-wrap:wrap;gap:4px;padding:2px 0 4px}
.tg{background:rgba(99,102,241,0.04);color:#818cf8;padding:2px 8px;border-radius:10px;font-size:9px;font-weight:500;transition:background .2s}
.tg:hover{background:rgba(99,102,241,0.1)}
.srcs{font-size:8px;color:#4a5a6d;line-height:1.6;padding:2px 0}

/* 底部 */
footer{padding:10px 0;text-align:center;font-size:8px;color:#2a3045}
#bt{position:fixed;bottom:50px;right:10px;width:28px;height:28px;border-radius:50%;background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.12);color:#818cf8;font-size:13px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:50;opacity:0;transition:opacity .3s,background .2s}
#bt:hover{background:rgba(99,102,241,0.15)}
@media(max-width:480px){.sg,.fg{grid-template-columns:1fr}.tl{font-size:16px}}

/* 精选卡片 */
.pc{border-left:3px solid #f59e0b;padding-left:10px;margin:8px 0;transition:background .2s;cursor:pointer;border-radius:0 4px 4px 0}
.pc:hover{background:rgba(245,158,11,0.04)}
.pc-top{display:flex;align-items:center;gap:6px}
.pc-ni{display:inline-flex;width:24px;height:24px;align-items:center;justify-content:center;border-radius:50%;color:#fff;font-size:12px;font-weight:700;flex-shrink:0}
.pc-tt{flex:1;font-size:13px;color:#f1f5f9;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pc-src{font-size:10px;color:#5a6a7d;flex-shrink:0}
.pc-sum{font-size:11px;color:#8896a6;margin:3px 0 0 30px;line-height:1.4}
.nsm{font-size:10px;color:#5a6a7d;margin:2px 0 0 20px;line-height:1.3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

/* 问答框 */
#qwrap{position:fixed;bottom:16px;right:16px;z-index:100;width:320px;max-width:calc(100vw - 32px)}
#qbox{background:rgba(17,21,36,0.97);border:1px solid rgba(99,102,241,0.2);border-radius:12px;padding:10px;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);box-shadow:0 8px 32px rgba(0,0,0,0.3)}
#qbox label{font-size:9px;color:#6b7a8d;display:block;margin-bottom:4px}
#qrow{display:flex;gap:6px}
#qinp{flex:1;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06);border-radius:8px;padding:7px 10px;color:#e2e8f0;font-size:11px;outline:none;transition:border-color .2s}
#qinp:focus{border-color:rgba(99,102,241,0.3)}
#qinp::placeholder{color:#4a5a6d}
#qbtn{background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.15);color:#818cf8;border-radius:8px;padding:7px 12px;font-size:11px;cursor:pointer;transition:background .2s}
#qbtn:hover{background:rgba(99,102,241,0.2)}
#qans{display:none;margin-top:6px;font-size:10px;color:#8896a6;line-height:1.5;padding:6px 8px;background:rgba(34,197,94,0.02);border-radius:6px}

/* 热力按钮 */
.heat-btn{display:inline-block;font-size:9px;padding:2px 10px;border-radius:8px;background:rgba(239,68,68,0.04);border:1px solid rgba(239,68,68,0.08);color:#ef4444;cursor:pointer;transition:background .2s;margin-left:6px}
.heat-btn:hover{background:rgba(239,68,68,0.08)}
</style>
</head>
<body>
<div class="app">
<header><div class="top"><span class="tl">📊 每日价值资讯</span><span class="live"></span></div><div class="sub"><span>5月28日 星期四</span><span class="gr">今日汇总</span><span>107条 · 12源</span></div><div class="wbar">🌤️ 北京 19&#176; Clear   &#168;4km/h</div><nav><a href="#gmarket">📊 大盘</a><a href="#gtrend">📈 趋势</a><a href="#gfinance">📈 投资·财经</a><a href="#gmacro">🌐 宏观·政策</a><a href="#ghot">🔥 热点·民生</a><a href="#gtech">💡 科技·前沿</a><a href="#goppo">🎯 机会·风向</a><a href="#gtrending">🏆 GitHub</a><a href="#s-v-煤炭">⛏️ 煤炭</a><a href="#s-v-银行">🏦 银行</a><a href="#s-v-基建">🏗️ 基建</a><a href="#s-v-钢铁">🔩 钢铁</a><a href="#s-v-公用事业">💡 公用事业</a><a href="#s-v-保险">🛡️ 保险</a><a href="#s-v-交运">🚄 交运</a><a href="#s-v-建材">🧱 建材</a><a href="#s-valuation" style="color:#22c55e">📋 低估值</a></nav></header>
